# Integration test environment — copy to `.env.test` and fill from `supabase status`.
#
#   cp .env.test.example .env.test   (then paste the local keys)
#
# `.env.test` is gitignored; never commit real keys. These point at the LOCAL
# Supabase stack (`npx supabase start`), never the cloud project.

# Local Supabase API gateway (default port from supabase/config.toml).
SUPABASE_URL=http://127.0.0.1:54321

# Local anon key — `supabase status` → "anon key". Safe-to-be-public, but still
# environment-specific, so it is not committed.
SUPABASE_KEY=<local anon key from `supabase status`>

# Local service_role key — `supabase status` → "service_role key". Used ONLY by
# the test process for admin seeding/teardown and DB-state read-back; it is never
# handed to the dev server. NEVER commit a real value.
SUPABASE_SERVICE_ROLE_KEY=<local service_role key from `supabase status`>
