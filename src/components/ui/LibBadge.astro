---
interface Props {
  label: string;
  version?: string;
}

const { label, version } = Astro.props;
---

<span
  class="border-border bg-card text-accent inline-flex items-center gap-2 rounded-lg border px-3 py-1.5 font-mono shadow-sm"
>
  {label}
  {version && <span class="bg-accent/20 text-accent rounded-full px-2 py-0.5 text-xs">{version}</span>}
</span>
