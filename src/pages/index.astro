---
import AppLayout from "@/layouts/AppLayout.astro";
import DeckComparer from "@/components/deck/DeckComparer";
---

<AppLayout title="DeckDelta" current="new">
  <div class="bg-cosmic min-h-screen w-full">
    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-8 sm:py-16">
      <header class="mb-8">
        <h1 class="font-display text-foreground text-3xl font-bold sm:text-4xl">DeckDelta</h1>
        <p class="text-muted-foreground mt-2 max-w-2xl text-sm sm:text-base">
          Paste your current deck and a target deck. DeckDelta shows what to remove, what to add, and what stays —
          grouped by card type.
        </p>
      </header>

      <DeckComparer client:load />
    </div>
  </div>
</AppLayout>
