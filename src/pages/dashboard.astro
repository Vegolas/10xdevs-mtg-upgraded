---
import AppLayout from "@/layouts/AppLayout.astro";

const { user } = Astro.locals;
---

<AppLayout title="Dashboard">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card rounded-md border p-8 text-center">
      <h1 class="font-display text-foreground mb-4 text-3xl font-semibold">Dashboard</h1>
      <p class="text-secondary-foreground">
        Welcome, <span class="text-foreground font-semibold">{user?.email}</span>
      </p>
      <p class="text-muted-foreground mt-2 text-sm">This page is only for authenticated users.</p>
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="font-display border-border bg-secondary text-secondary-foreground hover:text-foreground rounded-[5px] border px-4 py-2 text-[11px] tracking-[0.05em] uppercase transition-colors"
        >
          Sign out
        </button>
      </form>
    </div>
  </div>
</AppLayout>
