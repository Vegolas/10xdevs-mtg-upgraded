---
import AppLayout from "@/layouts/AppLayout.astro";
import NewPathForm from "@/components/path/NewPathForm";
import { createClient } from "@/lib/supabase";
import { toPathWithSummary } from "@/lib/api/paths";
import type { PathWithSummary } from "@/lib/api/paths";
import { formatUsd } from "@/components/deck/labels";
import { visibilityLabel } from "@/components/path/metadata";

// Middleware guards `/paths`, so a session exists; the cookie-bound client scopes
// the query to the owner via RLS. Steps are embedded (RLS-scoped, ordered by
// position) so each card can show real base→final metadata with no extra queries.
const supabase = createClient(Astro.request.headers, Astro.cookies);

let decks: PathWithSummary[] = [];
if (supabase) {
  const { data } = await supabase
    .from("upgrade_paths")
    .select("*, path_steps(*)")
    .order("created_at", { ascending: false })
    .order("position", { referencedTable: "path_steps", ascending: true });
  decks = (data ?? []).map((row) => toPathWithSummary(row, row.path_steps));
}

/** The grid metadata line: `~$cost · in/out · 🔒 private`. */
function metaLine({ summary, path }: PathWithSummary): string {
  const cost = summary.cost.pricedCount > 0 ? formatUsd(summary.cost.total) : "—";
  return `${cost} · ${summary.addCount}/${summary.removeCount} · ${visibilityLabel(path.visibility)}`;
}
---

<AppLayout title="Saved decks" current="paths">
  <div class="min-h-screen w-full">
    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-8 sm:py-16">
      <header class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <h1 class="font-display text-foreground text-2xl font-semibold sm:text-3xl">Saved decks</h1>
        <div class="flex items-center gap-2">
          {/* Static search — visual only, no behavior (deferred). */}
          <span
            class="border-border bg-input text-muted-foreground rounded-[5px] border px-3 py-1.5 text-xs"
            aria-disabled="true">⌕ search…</span
          >
          <a
            href="#new-path"
            class="font-display bg-primary text-primary-foreground rounded-[5px] border border-[#a9863f] px-3 py-1.5 text-[11px] font-semibold tracking-[0.05em] uppercase transition-opacity hover:opacity-90"
            >✦ New</a
          >
        </div>
      </header>

      {
        decks.length === 0 ? (
          <p class="border-border bg-card text-muted-foreground mb-6 rounded-md border p-4 text-sm">
            No saved decks yet. Use the tile below to start your first comparison.
          </p>
        ) : null
      }

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          decks.map((deck) => (
            <a
              href={`/paths/${deck.path.id}`}
              class="border-border bg-card hover:border-accent/50 block overflow-hidden rounded-md border transition-colors"
            >
              <div class="stripe relative h-[90px] border-b border-[#2d2417]">
                <span class="absolute bottom-1.5 left-1.5 rounded bg-[rgba(10,7,4,.65)] px-1.5 py-0.5 font-mono text-[9px] text-[#cdb98a]">
                  commander art
                </span>
              </div>
              <div class="p-3">
                <div class="font-display text-foreground truncate text-sm font-semibold">{deck.path.title}</div>
                <div class="text-muted-foreground mt-1 text-[10px]">{metaLine(deck)}</div>
              </div>
            </a>
          ))
        }
        <div id="new-path">
          <NewPathForm client:load />
        </div>
      </div>
    </div>
  </div>
</AppLayout>
