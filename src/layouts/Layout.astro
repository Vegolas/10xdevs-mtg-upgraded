---
import "../styles/global.css";
import Banner from "@/components/Banner.astro";
import { missingConfigs } from "@/lib/config-status";

interface Props {
  title?: string;
}

const { title = "10x Astro Starter" } = Astro.props;
const { user } = Astro.locals;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    {
      missingConfigs.map((cfg) => (
        <Banner variant="error">
          <strong>Uwaga:</strong> {cfg.message}
          {cfg.docsUrl && (
            <>
              {" "}
              <a href={cfg.docsUrl} target="_blank" rel="noopener noreferrer">
                {cfg.docsLabel ?? "Dokumentacja"}
              </a>
              .
            </>
          )}
        </Banner>
      ))
    }
    <header
      class="bg-cosmic flex items-center justify-end gap-4 border-b border-white/10 px-4 py-3 text-sm text-white sm:px-8"
    >
      {
        user ? (
          <>
            <a href="/paths" class="text-blue-100/80 transition-colors hover:text-white">
              My Paths
            </a>
            <span class="text-blue-100/50">{user.email}</span>
            <form method="POST" action="/api/auth/signout">
              <button
                type="submit"
                class="rounded-lg border border-white/20 bg-white/10 px-3 py-1.5 transition-colors hover:bg-white/20"
              >
                Sign out
              </button>
            </form>
          </>
        ) : (
          <>
            <a href="/auth/signin" class="text-blue-100/80 transition-colors hover:text-white">
              Sign in
            </a>
            <a
              href="/auth/signup"
              class="rounded-lg border border-white/20 bg-white/10 px-3 py-1.5 transition-colors hover:bg-white/20"
            >
              Sign up
            </a>
          </>
        )
      }
    </header>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
